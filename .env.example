# Copy this file to .env and fill in your Skybox API credentials
# Get tokens from Skybox → Settings → API

SKYBOX_APPLICATION_TOKEN=your_application_token_here
SKYBOX_API_TOKEN=your_api_token_here
SKYBOX_ACCOUNT_ID=your_account_id_here

# Set to true to block all write operations (PUT, POST, DELETE)
SKYBOX_READ_ONLY=false
